# CareerPilot Salone - Environment Variables
# Copy this file to .env.local and fill in your values

# ====================
# DATABASE (Supabase)
# ====================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ====================
# AI INTEGRATION
# ====================
# OpenAI API Key (for AI Chat, Roadmap Generator, Career Matching)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Alternative: Gemini API (optional fallback)
# GEMINI_API_KEY=your-gemini-api-key

# ====================
# SMS / WhatsApp (Twilio)
# ====================
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# Your bot's WhatsApp number (format: whatsapp:+1234567890)

# ====================
# DEPLOYMENT
# ====================
# Set to production on Vercel
NODE_ENV=production

# ====================
# VERIFICATION STATUS
# ====================
# ✅ OpenAI: Integrated in /api/chat, /api/generate-roadmap, /api/match-careers
# ✅ Twilio: Integrated in /api/whatsapp
# ✅ Supabase: Authentication & Database active
# 
# DEPLOYMENT CHECKLIST:
# [ ] Add all env vars to Vercel dashboard
# [ ] Test OpenAI chat on production
# [ ] Configure Twilio webhook URL
# [ ] Verify Supabase RLS policies
