# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Configuration
GEMINI_API_KEY=your-gemini-key
GOOGLE_GENERATIVE_AI_API_KEY=your-ge-ai-key

# OpenAI API key (Fallback/Legacy)
OPENAI_API_KEY=sk-xxxx
# Port for realtime socket server (optional)
SOCKET_PORT=3000
# Model used for streaming
OPENAI_STREAMING_MODEL=gpt-4o-mini

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp (Green API)
GREEN_API_ID_INSTANCE=
GREEN_API_TOKEN_INSTANCE=
GREEN_API_URL=https://7105.api.greenapi.com

# Optional Pinecone variables (if you enable RAG)
PINECONE_API_KEY=
PINECONE_ENV=
PINECONE_INDEX=
